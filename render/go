#!/bin/bash
#
# Render a Markdown file to generate a PDF.

set -eu -o pipefail

if [[ "$#" != 1 ]]; then
    echo "Usage: $0 <path/to/file>.md" >&2
    echo "Example: $0 'Cut_Lists/Interior Panels.md'" >&2
    exit 1
fi

INPUT="$(realpath "$1")"

cd "$(dirname "$0")/.."

export TZ="America/Los_Angeles"

function capitalize() {
    local orig="$1"
    local ret="${orig/.md/}"
    read -ra words <<< "${ret//_/ }"
    echo "${words[*]^}"
}

INPUT_FILE="$(basename "$INPUT")"
INPUT_DIR="$(basename "$(dirname "$INPUT")")"
TITLE="$(capitalize "$INPUT_DIR") \\ $(capitalize "$INPUT_FILE")"
REVISION_DATE="$(git log -1 --format="%cd" --date=format:"%Y-%m-%d %H:%M:%S" -- "${INPUT}")"
CREATION_TIMESTAMP="$(git log -1 --format="%ct" -- "$INPUT")"
# Handle new .md files that have no git log yet.
REVISION_DATE="${REVISION_DATE:-0000-00-00 00:00:00}"
CREATION_TIMESTAMP="${CREATION_TIMESTAMP:-0}"

OUTPUT_FILE="${INPUT_FILE/%.md/.pdf}"
export FOOTER="Revised $REVISION_DATE"

declare -a flags
flags=(pandoc -d ../render/pandoc-defaults.yaml --template ../render/typst-header.typ)
flags+=("--pdf-engine-opt=--root=/s")
flags+=("'$INPUT_FILE'" -o "'$OUTPUT_FILE'")
flags+=(-H '<(echo "#set page(footer: context { if counter(page).get().first() > 0 [$FOOTER #h(1fr) [#counter(page).display() / #counter(page).final().first()]] })")')
if ! grep -qF '#title-page[' "$INPUT"; then
    # No custom title-page, create a default one.
    flags+=(-V "title:\"$TITLE\"")
fi
# Make re-runs idempotent; typst embeds the "current" time into the .pdf, so set that "current" time to the last modification time of the input file.
flags+=("--pdf-engine-opt=--creation-timestamp=$CREATION_TIMESTAMP")

RUNNER="$(type -p docker || type -p podman)"
"$RUNNER" run --rm \
       -v "$PWD":/s:z \
       -w "/s/$INPUT_DIR" \
       -e FOOTER \
       -e TYPST_FONT_PATHS=/s/render/Carlito \
       --entrypoint=/bin/sh \
       ghcr.io/pandoc/typst:3.8.3 \
       -c \
       "${flags[*]}"
